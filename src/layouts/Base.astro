---
import Navbar from '@components/Navbar';
import '@styles/tokens.css';

interface Props {
  title: string;
  description?: string;
  theme?: 'default' | 'cool' | 'warm';
}

const { title, description = 'Future Frequencies — Immersive Deep House Experiences', theme = 'default' } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Navbar client:load theme={theme} />
    <slot />
  </body>
</html>

<style is:global>
  html {
    overflow-x: hidden;
  }

  body {
    overflow-x: hidden;
  }
</style>
