---
import Base from '@layouts/Base.astro';
import Hero from '@components/Hero';
import AutumnSeries from '@components/AutumnSeries';
import Philosophy from '@components/Philosophy';
import About from '@components/About';
import Journal from '@components/Journal';
import Newsletter from '@components/Newsletter';
import Footer from '@components/Footer';
---

<Base title="resonance — Immersive Deep House Experiences">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "resonance",
      "description": "Immersive deep house music experiences with premium sound systems and authentic community",
      "url": "https://www.resonanceevents.co.uk",
      "logo": "https://www.resonanceevents.co.uk/logo.png",
      "sameAs": [
        "https://www.instagram.com/futurefrequencies",
        "https://www.facebook.com/futurefrequencies"
      ],
      "foundingDate": "2024",
      "areaServed": {
        "@type": "City",
        "name": "Birmingham",
        "addressCountry": "GB"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "Customer Service",
        "email": "hello@futurefrequencies.co.uk"
      }
    }
  </script>

  <Hero client:load theme="default" />
  <AutumnSeries client:load theme="default" />
  <Philosophy client:load theme="default" />
  <About client:load theme="default" />
  <Journal client:load theme="default" />
  <Newsletter client:load theme="default" />
  <Footer client:load theme="default" />
</Base>
